*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# Environment — NEVER commit secrets
backend/.env
.env

# Local JSON data storage (dev fallback, not for source control)
backend/data/

# ── Flutter / Dart ─────────────────────────────────────────────────────────────
flutter_app/.dart_tool/
flutter_app/.flutter-plugins
flutter_app/.flutter-plugins-dependencies
