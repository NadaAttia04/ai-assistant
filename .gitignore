flutter_app/build/
flutter_app/pubspec.lock

# Android
flutter_app/android/.gradle/
flutter_app/android/local.properties
flutter_app/android/captures/
flutter_app/android/key.properties
*.keystore
*.jks

# iOS
flutter_app/ios/.symlinks/
